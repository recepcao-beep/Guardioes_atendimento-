# CLIENT-SIDE VARIABLES (Exposed to Vite bundle, must use VITE_ prefix)
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_PUBLIC_KEY"
VITE_APP_URL="http://localhost:3000"

# SERVER-SIDE ONLY SECRETS (Never exposed to the client browser)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY_SECRET"
ADMIN_INITIAL_PASSWORD="0000"
ADMIN_INTERNAL_EMAIL="admin@hotelreviews.internal"

# PYTHON ROBOT ONLY (local machine or scheduled worker)
MYHOTEL_LOGIN_URL="https://fidelity.myhotel.cl/login"
MYHOTEL_USER="your-myhotel-user"
MYHOTEL_PASSWORD="your-myhotel-password"
ROBOT_DRY_RUN="true"
ROBOT_HEADLESS="false"
MYHOTEL_REQUIRE_SOURCE_MATCH="true"
MATCH_THRESHOLD="0.86"

# VERCEL API -> GITHUB ACTIONS DISPATCH
# Store these in Vercel, not in the browser.
GITHUB_ACTIONS_TOKEN="github_pat_or_classic_token_with_actions_write"
GITHUB_ACTIONS_OWNER="recepcao-beep"
GITHUB_ACTIONS_REPO="Guardioes_atendimento-"
GITHUB_ACTIONS_WORKFLOW_ID="myhotel-reconciliation-robot.yml"
GITHUB_ACTIONS_BOOKING_WORKFLOW_ID="hits-booking-leads-robot.yml"
GITHUB_ACTIONS_REF="main"

# GITHUB ACTIONS SECRETS FOR HITS BOOKING ROBOT
HITS_USER="your-hits-user"
HITS_PASSWORD="your-hits-password"
